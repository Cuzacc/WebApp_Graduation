# ==========================================
# Cấu hình Môi trường cho Graduation App
# ==========================================

# 1. DATABASE CONFIG (PostgreSQL)
# Chỉnh sửa credentials tương ứng với database của anh
DB_USER=admin
DB_PASSWORD=secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=graduation_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# 2. BACKEND (FastAPI API)
API_PORT=8000
API_HOST=0.0.0.0
# Chuỗi siêu bí mật để mã hóa Token Đăng nhập của Admin
SECRET_KEY=vui_long_thay_doi_chuoi_nay_thanh_1_mat_khau_that_dai
# Hạn sử dụng của Token đăng nhập (Phút)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 3. EMAIL WORKER CONFIG
# Thông tin để gọi SMTP tự động gửi mail cảm ơn khách
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=anh_email_cua_anh@gmail.com
# Vui lòng tạo App Password trên Gmail để sử dụng, không dùng Pass gốc
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# 4. FRONTEND (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Ngày Lễ Tốt Nghiệp để đếm ngược (YYYY-MM-DDTHH:mm:SS)
NEXT_PUBLIC_GRADUATION_DATE=2026-06-30T09:00:00
